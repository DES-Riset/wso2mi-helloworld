<?xml version="1.0" encoding="UTF-8"?>
<api context="/hello-world" name="Hello-World" version="1.0.0" version-type="url"
    xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="GET" uri-template="/">
        <inSequence>
            <payloadFactory media-type="json" template-type="default">
                <format>{
                    "message": "Hello World"
                    }</format>
            </payloadFactory>
            <respond description="Hello"/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
</api>